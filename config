config-file = ?auto/theme.ghostty
title = " "
maximize = true
working-directory = "home"
shell-integration = "zsh"
# initial-command = "~/.config/ghostty/startup.sh"
quit-after-last-window-closed = true
quick-terminal-screen = mouse
quick-terminal-autohide = true
scrollback-limit = 524288000
clipboard-read = allow
clipboard-write = allow
clipboard-paste-protection = false
clipboard-paste-bracketed-safe = true
copy-on-select = clipboard
window-inherit-working-directory = true
window-save-state = "always"
window-padding-x = 10
window-padding-y = 10
window-height = 40
window-width = 150
# theme = "Adventure Time"
theme = "Monokai Pro Octagon"
font-size = 16
font-family = "Hack Nerd Font Mono"
# Quick terminal (drop-down)
keybind = global:cmd+grave_accent=toggle_quick_terminal

# Tmux-style keybindings (leader: cmd+a)
keybind = cmd+a>c=new_tab
keybind = cmd+a>x=close_surface
keybind = cmd+a>n=next_tab
keybind = cmd+a>p=previous_tab
keybind = cmd+a>digit_1=goto_tab:1
keybind = cmd+a>digit_2=goto_tab:2
keybind = cmd+a>digit_3=goto_tab:3
keybind = cmd+a>digit_4=goto_tab:4
keybind = cmd+a>digit_5=goto_tab:5
keybind = cmd+a>minus=new_split:down
keybind = cmd+a>backslash=new_split:right
keybind = cmd+a>left=goto_split:left
keybind = cmd+a>right=goto_split:right
keybind = cmd+a>up=goto_split:up
keybind = cmd+a>down=goto_split:down
keybind = cmd+a>equal=equalize_splits
keybind = cmd+a>z=toggle_split_zoom
keybind = cmd+a>f=toggle_fullscreen

mouse-hide-while-typing = true
app-notifications = no-clipboard-copy
macos-titlebar-proxy-icon = "hidden"
quick-terminal-position = "top"
auto-update = "check"
auto-update-channel = "tip"
macos-icon = "custom-style"
macos-icon-frame = "beige"
macos-icon-screen-color = 1f1d45
shell-integration-features = ssh-env,ssh-terminfo
